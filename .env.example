# Application
NODE_ENV=development
PORT=3000

# CORS (URLs del frontend)
# Si no se especifica, por defecto permite: localhost:5173, localhost:5174, localhost:5175, localhost:3000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Firebase Admin SDK
# Opción 1: Service Account Path
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Opción 2: Variables individuales (para deployment en cloud)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Firebase Storage
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
# Modelo dedicado a análisis de métricas/insights (opcional, hereda ANTHROPIC_MODEL si se omite)
ANTHROPIC_ANALYTICS_MODEL=claude-sonnet-4-6
# Tiers de extracción (recibo/voz) — homologados con gastos-firebase-functions
# vía el paquete @gastos/expense-ai. Opcionales (defaults en el paquete).
ANTHROPIC_MODEL_PRIMARY=claude-sonnet-4-6
ANTHROPIC_MODEL_HELPER=claude-haiku-4-5
# Admin API key de Anthropic (OPCIONAL) — SOLO para el panel admin:
# leer el Cost Report de la organización (gasto facturado, NO saldo).
# OJO: el Admin API de Anthropic NO existe para cuentas individuales —
# requiere una ORGANIZACIÓN y ser admin de ella (Console → Settings →
# Organization; puede requerir plan de org). Recién ahí: API Keys →
# Admin keys → "Create Admin Key" (sk-ant-admin...). Si tu cuenta es
# personal, dejala vacía: el panel muestra el estimado + link a consola.
ANTHROPIC_ADMIN_KEY=

# OpenAI (OPCIONAL — solo para la ilustración IA del roast de Métricas)
# Si se deja vacío, el endpoint /api/analytics/ai-image queda deshabilitado
# y el frontend oculta el botón "Ilustración IA".
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_MODEL_TRANSCRIBE=gpt-4o-mini-transcribe
# Admin API key de OpenAI (OPCIONAL) — SOLO para el panel admin: leer el
# Costs API de la organización (gasto facturado, NO saldo). NO está en la
# página normal de API keys: créala (org owner) en
# https://platform.openai.com/settings/organization/admin-keys
OPENAI_ADMIN_KEY=

# Consumo IA — tarifas estimadas (opcional, defaults razonables)
AI_PRICE_ANTHROPIC_INPUT_PER_1M=3
AI_PRICE_ANTHROPIC_OUTPUT_PER_1M=15
AI_PRICE_OPENAI_IMAGE_USD=0.04
AI_PRICE_WHISPER_PER_MIN_USD=0.006

# Consumo IA — cuotas por usuario/mes (Fase 2). admin = ilimitado.
# Solo cuenta el consumo scope:"user". Bloqueo al 100%, aviso al WARN_PCT%.
AI_QUOTA_STANDARD_TOKENS=100000
AI_QUOTA_PRO_TOKENS=2000000
AI_QUOTA_STANDARD_IMAGES=0
AI_QUOTA_PRO_IMAGES=50
AI_QUOTA_WARN_PCT=80

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
SCAN_THROTTLE_LIMIT=10
AI_THROTTLE_LIMIT=20

# Logging
LOG_LEVEL=debug

# Cron Trigger (Programados)
# Token compartido con el scheduler externo (GitHub Actions) que dispara
# POST /api/programados/cron/run en producción (Vercel serverless). En local
# es opcional: el @Cron de @nestjs/schedule sigue corriendo cada 30 min.
# Generar con: openssl rand -hex 32
CRON_SECRET=
